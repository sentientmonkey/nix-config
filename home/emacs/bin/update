#!/usr/bin/env bash
set -euo pipefail

BOOTSTRAP="$HOME/.emacs.d/straight/repos/straight.el/bootstrap.el"

if [ -f "$BOOTSTRAP" ]; then
  # straight.el already installed — pull all packages and freeze versions
  emacs --batch -Q \
    --eval "(load \"$BOOTSTRAP\" nil 'nomessage)" \
    --eval "(straight-pull-all)" \
    --eval "(straight-freeze-versions)" 2>&1
else
  # First run — load full init.el to bootstrap straight.el and install everything
  emacs --batch --load "$HOME/.emacs.d/init.el" 2>&1
fi
